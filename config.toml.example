log_format = "text"
local = false

[smtp]
listen_addr = ":25"
domain = "mail.example.com"
max_message_size = 10485760
timeout_duration = "10s"
min_tls_version = "1.2"
check_x_spam_flag = true
dmarc_quarantine_as_junk = true
require_sender_mx = true
shutdown_timeout = "1m0s"
max_connections = 100
max_connections_per_ip = 10

[smtp.rate_limit]
enabled = true
gossip_enabled = false
gossip_interval = "5s"

[[smtp.rate_limit.dimensions]]
name = "per_ip"
keys = ["IP"]
limit = 60
window = "1m0s"
[smtp.distributed]
enabled = false
global_max_per_ip = 0
gossip_interval = "5s"
s3_sync_interval = "30s"
recipient_cache_ttl = "15m0s"

[dns]
servers = []
timeout = "5s"

[s3]
endpoint = "s3.amazonaws.com"
bucket = "email-mx-certs"
prefix = "certs/"
access_key_id = "your-s3-access-key-id"
secret_access_key = "your-s3-secret-access-key"
region = "us-east-1"

[destination]
url = "https://your-worker.example.com/email"
api_key = "your-api-key-here"
max_retry_attempts = 3
http_timeout = "30s"
[destination.circuit_breaker]
enabled = true
failure_threshold = 5
success_threshold = 2
timeout = "30s"
half_open_max_calls = 1
reset_timeout = "1m0s"

[tls]
email = "admin@example.com"
use_production = true
use_local_ca = false
certmagic_verbose = false

[blacklists]
enabled = true
lists = ["zen.spamhaus.org"]
timeout = "3s"
check_helo_resolves = false

[health]
enabled = true
listen_addr = ":8080"
username = ""
password = ""

[stats]
enabled = true
retention_duration = "24h0m0s"
sync_enabled = false
sync_interval = "1m0s"
max_ip_entries = 100000
max_domain_entries = 50000

[cluster]
enabled = false
node_name = ""         # Auto-detected from hostname if empty
bind_addr = "0.0.0.0"  # Address to bind memberlist to
bind_port = 7946       # Memberlist gossip port (standard port)
advertise_addr = ""    # Address to advertise to peers (auto-detected if empty)
advertise_port = 0     # Port to advertise (defaults to bind_port if 0)
seed_nodes = []        # Initial nodes to join, e.g., ["node1.example.com:7946", "node2.example.com:7946"]
